{
  "name": "@r4pm/components",
  "version": "0.1.1",
  "description": "Reusable viewers (DFG, Petri net, dotted chart, OCEL, alignments) and inputs for process mining",
  "keywords": [
    "process-mining",
    "object-centric",
    "ocel",
    "petri-net",
    "directly-follows-graph",
    "dfg",
    "event-log",
    "xes",
    "conformance-checking",
    "alignments",
    "dotted-chart",
    "react",
    "visualization"
  ],
  "repository": "https://github.com/aarkue/propel",
  "homepage": "https://github.com/aarkue/propel",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./ui": "./src/ui/index.ts",
    "./ui/styles.css": "./src/ui/styles.css",
    "./petri": "./src/petri/index.ts",
    "./petri/editor.css": "./src/petri/editor/editor.css",
    "./charts": "./src/charts/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "docs:types": "node scripts/gen-data-types-doc.mjs && node scripts/gen-component-types-doc.mjs",
    "dev": "storybook dev -p 6006 --no-open",
    "showcase": "storybook build",
    "build": "tsup && tailwindcss -i src/styles.css -o dist/styles.css --minify && tailwindcss -i src/ui/styles.css -o dist/ui/styles.css --minify",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@radix-ui/themes": "^3.2.1",
    "@tanstack/react-virtual": "^3.14.5",
    "@xyflow/react": "^12.10.0",
    "elkjs": "^0.10.0",
    "html-to-image": "^1.11.11",
    "react-icons": "^5.5.0",
    "react-plotly.js": "^2.6.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10",
    "@storybook/react-vite": "^10",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.67.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-plotly.js": "^2.6.3",
    "plotly.js": "^2.35.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remark-gfm": "^4.0.1",
    "storybook": "^10",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "license": "MIT OR Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles.css": "./dist/styles.css",
      "./ui": {
        "types": "./dist/ui/index.d.ts",
        "import": "./dist/ui/index.js"
      },
      "./ui/styles.css": "./dist/ui/styles.css",
      "./petri": {
        "types": "./dist/petri/index.d.ts",
        "import": "./dist/petri/index.js"
      },
      "./petri/editor.css": "./dist/petri/index.css",
      "./charts": {
        "types": "./dist/charts/index.d.ts",
        "import": "./dist/charts/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "sideEffects": [
    "**/*.css"
  ]
}